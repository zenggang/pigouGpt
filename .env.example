SUB2API_BASE_URL=https://your-sub2api-host.example.com/ai/v1
SUB2API_KEY=your-sub2api-key-here

# 推荐生产方式：Next.js 服务端调用 ECS 内部数据库 API，ECS API 再访问本机 MySQL。
DATABASE_API_BASE_URL=https://your-private-db-api.example.com
DATABASE_API_KEY=your-database-api-key-here

# ECS pigou-db-api 需要同时配置这些变量，用于后台异步生成图片和拼接公开图片 URL。
PIGOU_PUBLIC_BASE_URL=https://your-private-db-api.example.com
# SUB2API_BASE_URL=https://your-sub2api-host.example.com/ai/v1
# SUB2API_KEY=your-sub2api-key-here

# 可选本地/隧道直连 MySQL 回退；配置 DATABASE_API_* 时不会使用 DATABASE_URL。
# DATABASE_URL=mysql://pigou_console:your-password@127.0.0.1:3306/your_app_database
MYSQL_CONNECTION_LIMIT=4

# 初始化允许登录的账号；不要把真实密码提交到代码仓库
INITIAL_USER_EMAILS=admin@example.com,operator@example.com
INITIAL_USER_PASSWORD=change-this-before-running-db-setup
AUTH_SESSION_DAYS=7
